[{"id": 13, "category": "solar", "season": "夏季", "term": "立夏", "poem": "立夏", "author": "陆游", "dynasty": "宋", "content": "赤帜插城扉，东君整驾归。\n泥新巢燕闹，花尽蜜蜂稀。\n槐柳阴初密，帘栊暑尚微。\n日斜汤沐罢，熟练试单衣。", "translation": "夏天来了，燕子在新泥中筑巢，花儿凋谢，槐柳树荫变浓，人们换上了单衣。", "authorIntro": "陆游（1125-1210），南宋爱国诗人。", "background": "立夏时节", "imagePrompt": "Summer", "quizzes": [{"q": "这首诗是写什么节气？", "options": ["立春", "立夏", "夏至", "小满"], "answer": 1, "explanation": "诗题是立夏。"}, {"q": "人们换上了什么衣服？", "options": ["棉衣", "单衣", "毛衣", "皮衣"], "answer": 1, "explanation": "熟练试单衣。"}, {"q": "燕子在做什么？", "options": ["迁徙", "筑巢", "休息", "歌唱"], "answer": 1, "explanation": "泥新巢燕闹。"}]}, {"id": 14, "category": "solar", "season": "夏季", "term": "立夏", "poem": "池上", "author": "白居易", "dynasty": "唐", "content": "小娃撑小艇，偷采白莲回。\n不解藏踪迹，浮萍一道开。", "translation": "小孩子撑着一条小船，偷偷地采了白莲回来。不知道要掩盖自己留下的踪迹，水面上的浮萍被船分开，留下了一道痕迹。", "authorIntro": "白居易（772-846），唐代伟大诗人。", "background": "夏天荷塘里儿童偷采莲蓬", "imagePrompt": "Summer lotus pond", "quizzes": [{"q": "小娃偷采了什么？", "options": ["红莲", "白莲", "睡莲", "莲花"], "answer": 1, "explanation": "偷采白莲回。"}, {"q": "踪迹被什么暴露了？", "options": ["脚印", "浮萍一道开", "声音", "气味"], "answer": 1, "explanation": "浮萍一道开。"}, {"q": "什么季节？", "options": ["春天", "夏天", "秋天", "冬天"], "answer": 1, "explanation": "夏天荷塘里有莲花。"}]}]